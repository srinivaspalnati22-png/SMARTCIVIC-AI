# SmartCivic SMS Configuration
# Copy this file to .env and fill in your credentials

# ============ OPTION 1: Fast2SMS (FREE for India) ============
# Sign up at https://www.fast2sms.com/ to get free API key
# Free tier: Unlimited OTP/Transactional SMS
# ============ OPTION 1: Fast2SMS (FREE for India) ============
# Sign up at https://www.fast2sms.com/ to get free API key
# Free tier: Unlimited OTP/Transactional SMS
FAST2SMS_API_KEY=UxwevkEd4XhyY9ZlwYHSOE8QjFC9HZrZAwoI7wCl1gEmswOoyh8AxWnS5Qtb
GEMINI_API_KEY="AIzaSyBPMlm4y9E0XTFSJCVOilbq1ECD_hHixAw"

# ============ OPTION 2: Twilio (Paid, Global) ============
# Sign up at https://www.twilio.com/ for international SMS
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM=+1234567890

# ============ OPTION 3: TextBelt (Free tier) ============
# Uses free public API - 1 SMS per day limit
# No configuration needed - works automatically as fallback

# ============ OPTION 4: WhatsApp via CallMeBot (FREE!) ============
# This sends messages directly to WhatsApp!
# 
# SETUP STEPS:
# 1. Save this number in your phone: +34 644 71 70 78
# 2. Open WhatsApp and send this EXACT message to that number:
#    "I allow callmebot to send me messages"
# 3. Wait for the response with your API key
# 4. Add your phone number (with country code, no +) and API key below:
WHATSAPP_PHONE=919876543210
CALLMEBOT_API_KEY=123456

# ============ Flask Settings ============
FLASK_ENV=development

# ============ Instructions ============
# 1. For Indian numbers: Use Fast2SMS (free and easy)
#    - Create account at fast2sms.com
#    - Go to Dev API section
#    - Copy your API key and paste above
#
# 2. For WhatsApp: Use CallMeBot (FREE and reliable)
#    - Follow the setup steps above
#    - Works instantly after activation
#
# 3. For international SMS: Use Twilio
#    - Create Twilio account
#    - Get Account SID and Auth Token from dashboard
#    - Get a Twilio phone number
#
# 4. The system will try each method in order:
#    Fast2SMS → Twilio → TextBelt → WhatsApp → Console log
